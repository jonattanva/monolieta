{
    "private": true,
    "author": "Jonattan Velásquez",
    "license": "GPL-3.0",
    "scripts": {
        "prettier": "prettier --write src/",
        "start:web": "webpack serve --mode=development --watch",
        "test": "jest",
        "test:code": "eslint --max-warnings 0 --ext .jsx,.js . && flow",
        "test:coverage": "jest --coverage"
    },
    "dependencies": {
        "@simonwep/pickr": "~1.8.0",
        "nanoid": "~3.1.20",
        "react": "~17.0.1",
        "react-custom-scrollbars": "~4.2.1",
        "react-dom": "~17.0.1",
        "react-select": "~4.0.2",
        "styled-components": "~5.2.1"
    },
    "devDependencies": {
        "@babel/core": "~7.12.10",
        "@babel/preset-env": "~7.12.11",
        "@babel/preset-flow": "~7.12.1",
        "@babel/preset-react": "~7.12.10",
        "@testing-library/react": "~11.2.3",
        "babel-eslint": "~10.1.0",
        "babel-jest": "~26.6.3",
        "babel-loader": "~8.2.2",
        "babel-plugin-styled-components": "~1.12.0",
        "css-loader": "~5.0.1",
        "eslint": "~7.18.0",
        "eslint-config-prettier": "~7.2.0",
        "eslint-plugin-babel": "~5.3.1",
        "eslint-plugin-jest": "~24.1.3",
        "eslint-plugin-react": "~7.22.0",
        "eslint-plugin-react-hooks": "~4.2.0",
        "flow-bin": "~0.143.1",
        "flow-typed": "~3.2.1",
        "identity-obj-proxy": "~3.0.0",
        "jest": "~26.6.3",
        "jest-styled-components": "~7.0.3",
        "prettier": "~2.2.1",
        "react-test-renderer": "~17.0.1",
        "style-loader": "~2.0.0",
        "webpack": "~5.18.0",
        "webpack-cli": "~4.4.0",
        "webpack-dev-server": "~3.11.2"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/jonattanva/eva.git"
    },
    "jest": {
        "coverageReporters": [
            "html",
            "lcov",
            "text-summary"
        ],
        "moduleFileExtensions": [
            "js",
            "jsx",
            "json"
        ],
        "moduleNameMapper": {
            "\\.(css)$": "identity-obj-proxy",
            "component/(.*)": "<rootDir>/src/view/component/$1/index.jsx",
            "^\\hook(.*)$": "<rootDir>/src/view/hook$1",
            "^\\utils(.*)$": "<rootDir>/src/utils$1",
            "^\\workspace(.*)$": "<rootDir>/src/view/workspace$1"
        }
    }
}
