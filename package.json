{
    "private": true,
    "author": "Jonattan Velásquez",
    "license": "GPL-3.0",
    "scripts": {
        "build:web": "webpack --mode=production",
        "clean:cache": "rm -R ./node_modules/.cache",
        "cypress": "node ./node_modules/.bin/cypress open",
        "prettier": "prettier --write src/",
        "start:web": "webpack serve --mode=development --host=0.0.0.0",
        "test": "jest",
        "test:chrome": "cypress run --browser chrome",
        "test:code": "eslint --max-warnings 0 --ext .jsx,.js . && flow",
        "test:coverage": "jest --coverage"
    },
    "dependencies": {
        "@simonwep/pickr": "~1.8.0",
        "nanoid": "~3.1.20",
        "react": "~17.0.1",
        "react-dom": "~17.0.1",
        "react-is": "~17.0.1",
        "react-select": "~4.1.0",
        "styled-components": "~5.2.1"
    },
    "devDependencies": {
        "@babel/core": "~7.12.16",
        "@babel/eslint-parser": "~7.12.16",
        "@babel/plugin-transform-runtime": "~7.12.15",
        "@babel/preset-env": "~7.12.16",
        "@babel/preset-flow": "~7.12.13",
        "@babel/preset-react": "~7.12.13",
        "@babel/runtime-corejs3": "~7.12.13",
        "@testing-library/react": "~11.2.5",
        "babel-jest": "~26.6.3",
        "babel-loader": "~8.2.2",
        "babel-plugin-styled-components": "~1.12.0",
        "clean-webpack-plugin": "~3.0.0",
        "copy-webpack-plugin": "~7.0.0",
        "css-loader": "~5.0.2",
        "cypress": "~6.5.0",
        "eslint": "~7.20.0",
        "eslint-config-prettier": "~7.2.0",
        "eslint-plugin-babel": "~5.3.1",
        "eslint-plugin-jest": "~24.1.3",
        "eslint-plugin-prettier": "~3.3.1",
        "eslint-plugin-react": "~7.22.0",
        "eslint-plugin-react-hooks": "~4.2.0",
        "flow-bin": "~0.144.0",
        "flow-typed": "~3.2.1",
        "html-loader": "~2.0.0",
        "html-webpack-plugin": "~5.1.0",
        "identity-obj-proxy": "~3.0.0",
        "jest": "~26.6.3",
        "jest-styled-components": "~7.0.3",
        "prettier": "~2.2.1",
        "size-plugin": "~3.0.0",
        "style-loader": "~2.0.0",
        "webpack": "~5.22.0",
        "webpack-cli": "~4.5.0",
        "webpack-dev-server": "~3.11.2"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/jonattanva/monolieta.git"
    },
    "engines": {
        "node": ">=15.0.0"
    },
    "jest": {
        "coverageReporters": [
            "html",
            "lcov",
            "text-summary"
        ],
        "moduleFileExtensions": [
            "js",
            "jsx",
            "json"
        ],
        "moduleNameMapper": {
            "Monolieta": "<rootDir>/flow-typed/monolieta.js",
            "\\.(css)$": "identity-obj-proxy",
            "^\\hook(.*)$": "<rootDir>/src/hook$1",
            "^\\library(.*)$": "<rootDir>/src/library/$1/index",
            "component/(.*)": "<rootDir>/src/component/$1/index",
            "util/(.*)$": "<rootDir>/src/util$1",
            "view/(.*)": "<rootDir>/src/view/$1/index"
        }
    }
}
